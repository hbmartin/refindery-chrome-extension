{
  "name": "refindery-extension",
  "version": "0.1.0",
  "description": "Chrome extension upstream source for Refindery — auto-captures pages you read and ingests them into a local Refindery instance.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "npm run format:check && npm run lint:code && npm run lint:architecture && npm run lint:semgrep",
    "lint:code": "oxlint .",
    "lint:architecture": "depcruise src --config .dependency-cruiser.cjs",
    "lint:semgrep": "semgrep scan --error --metrics=off --config .semgrep.yml",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=high",
    "check:package": "node scripts/validate-build.mjs",
    "mock": "node mock-server/index.mjs",
    "zip": "cd dist && zip -r ../refindery-extension.zip . && cd .."
  },
  "dependencies": {
    "dompurify": "^3.2.3",
    "preact": "^10.25.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^16.10.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^5.6.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
